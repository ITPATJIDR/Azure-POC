# ─────────────────────────────────────────────────────────────────────────────
#  terraform.tfvars.example
#  Copy to terraform.tfvars and fill in the sensitive values before running
#  tofu plan / tofu apply
# ─────────────────────────────────────────────────────────────────────────────

# ── Project ───────────────────────────────────────────────────────────────────
project_name        = "scg"
environment         = "dev"
location            = "southeastasia"
resource_group_name = "scg-dev-rg"

# ── AKS ───────────────────────────────────────────────────────────────────────
aks_system_vm_size    = "Standard_D2s_v3"
aks_system_node_count = 2
aks_user_vm_size      = "Standard_D2s_v3"
aks_user_node_count   = 2
aks_admin_username    = "aksadmin"

# REQUIRED: paste your SSH public key here
ssh_public_key = "ssh-rsa AAAA... your-key-here"

# ── Database ──────────────────────────────────────────────────────────────────
db_admin_login    = "todoadmin"
db_sku_name       = "B_Standard_B1ms"  # Use GP_Standard_D2s_v3 for production
db_storage_mb     = 32768              # 32 GB

# REQUIRED: set a strong password (min 8 chars, upper+lower+digit+special)
db_admin_password = "ChangeMeStrong123!"
